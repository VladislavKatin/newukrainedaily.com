{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/tick",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/fetch-news",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/rewrite-news",
      "schedule": "5,20,35,50 * * * *"
    },
    {
      "path": "/api/cron/generate-images",
      "schedule": "10,40 * * * *"
    },
    {
      "path": "/api/cron/publish",
      "schedule": "15,45 * * * *"
    }
  ]
}
